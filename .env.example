JWT_SECRET=test1234
REFRESH_TOKEN_SECRET=test1234

PORT=3000
API_DOMAIN='http://localhost:3000'
STATIC_MEDIA_HOST=http://localhost:3000

# NGINX_PORT=3001
MEDIA_LOCATION=./data/media/
TEMP_LOCATION=/tmp/data/media/

DATABASE_URL="postgresql://nomads:nomads@pgsql:5432/nomads?schema=public"
POSTGRES_LOCAL_MACHINE_PORT=5434
POSTGRES_PASSWORD=nomads
POSTGRES_USER=nomads

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=password

MINIO_HOST=minio
MINIO_ROOT_USER=blackbird
MINIO_ROOT_PASSWORD=password
MINIO_API_PORT=9000
# Optional: a browser-reachable host for MinIO, used to presign download URLs
# in development (docker-compose maps the MinIO API port to the host). When
# unset, downloads are streamed through the API instead of presigned.
# MINIO_PUBLIC_HOST=localhost
# MINIO_PUBLIC_PORT=9000

MAILHOG_PORT=1025

STRIPE_KEY=

# Which object storage to use: "minio" or "s3" (Backblaze, Hetzner, etc.).
# Usually unnecessary: when unset, Mirlo uses an S3 service if the S3
# credentials below are filled in, and MinIO otherwise.
# STORAGE_BACKEND=minio

S3_ACCESS_KEY_ID=
S3_KEY_NAME=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_ENDPOINT=

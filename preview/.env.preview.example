# Shared env for preview stacks. Copy to preview/.env.preview on the preview host.
#
# Internal service hostnames (pgsql / redis / minio) resolve within each preview's
# own Compose network, so this single file is reused by every preview. Per-preview
# values (API_DOMAIN, STATIC_MEDIA_HOST) are injected by docker-compose.preview.yml
# from $PREVIEW_SUBDOMAIN — do not set them here.
#
# This is a throwaway sandbox: these secrets are not real. Do NOT point a preview
# host at production credentials or buckets.

# Auth — any value works; previews are isolated sandboxes.
JWT_SECRET=preview-not-secret
REFRESH_TOKEN_SECRET=preview-not-secret

PORT=3000
MEDIA_LOCATION=./data/media/
TEMP_LOCATION=/tmp/data/media/

# Postgres — matches the pgsql service in docker-compose.preview.yml.
POSTGRES_USER=nomads
POSTGRES_PASSWORD=nomads
POSTGRES_DB=nomads
DATABASE_URL="postgresql://nomads:nomads@pgsql:5432/nomads?schema=public"

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=preview-not-secret

# MinIO
MINIO_HOST=minio
MINIO_ROOT_USER=blackbird
MINIO_ROOT_PASSWORD=preview-not-secret
MINIO_API_PORT=9000

# Stripe left empty — payments are inert in previews.
STRIPE_KEY=

# External S3 unused; previews use the bundled MinIO.
S3_ACCESS_KEY_ID=
S3_KEY_NAME=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_ENDPOINT=

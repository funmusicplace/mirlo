extends ../layout.pug

block content
    p Hi,
    - const supportMessage = artist?.properties?.emails?.support
    if supportMessage
      div!= supportMessage
    p
      | Thank you for supporting #{artist.name} with your #{interval === 'MONTH' ? 'monthly': 'yearly'} 
      | support at the "#{profileUserSubscription.profileSubscriptionTier.name}" tier.
    table 
      tr 
        td #{artist.name}
        td.pa3 #{profileUserSubscription.amount / 100} #{artist.user.currency}
    p To view all your subscriptions log in or create an account with this email address.
    
    p Thank you!

extends ../layout.pug

block content
  p
    | Hello #{track.trackGroup.profile.user.name}!
  p
    | Someone (#{email}) bought a digital copy of
    |
    strong #{track.trackGroup.title}.
  p
    | From album:
    |
    strong #{track.trackGroup.title}
  p
    | #{purchase.currencyPaid.toUpperCase()} #{pricePaid.toFixed(2)} (Mirlo percentage: #{track.trackGroup.platformPercent}% (#{purchase.currencyPaid.toUpperCase()} #{platformCut.toFixed(2)}))
  p
    | Final:
    |
    strong #{purchase.currencyPaid.toUpperCase()} #{(pricePaid - platformCut).toFixed(2)}

  if message
    p
      | The buyer left a message for you:
      |
      em "#{message}"

  p The final money will be available via your Stripe dashboard
  p If you have any questions please reach out to hi@mirlo.space

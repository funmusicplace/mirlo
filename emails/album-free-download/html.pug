extends ../layout.pug

block content
  p Woohoo!
  p
    | Here's your free download of
    |
    strong #{trackGroup.title}
    |
    | by
    |
    strong #{trackGroup.artist.name}.

  table
    thead
      tr
        th Title
        th Download
    tbody
      tr
        td #{trackGroup.title}
        td
          a(href!=`${client}/${trackGroup.artist.urlSlug}/release/${trackGroup.urlSlug}/download?token=${token}&email=${email}`) download

  p
    | Consider supporting
    |
    a(href!=`${client}/${trackGroup.artist.urlSlug}`) #{trackGroup.artist.name}
    |
    | with a subscription or a purchase.
  p Enjoy!

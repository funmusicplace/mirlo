extends ../layout.pug

block content
  p 
    | Here's your download of 
    strong #{trackGroup.title} 
    | by 
    strong #{trackGroup.artist.name}.
  table 
    tr 
      td #{trackGroup.title}
      td 
        a(href!=`${client}/${trackGroup.artist.urlSlug}/release/${trackGroup.urlSlug}/download?token=${token}&email=${email}`) download

  p 
  p 
    | Consider supporting 
    a(href!=`${client}/${trackGroup.artist.urlSlug}`) #{trackGroup.artist.name}
    | with a subscription.
  p
    | If you want to have access to all your purchases for this e-mail address,
    | simply
    a(href!=`${client}/password-reset?email=${email}`) set a password for it
    | .
  - const purchaseMessage = trackGroup.artist?.properties?.emails?.purchase
  if purchaseMessage
    div!= purchaseMessage
  else
    p Enjoy!

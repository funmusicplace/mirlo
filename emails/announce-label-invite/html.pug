extends ../layout.pug

block content
  p 
    | Hi #{(user && user.name) || 'there'},
  p 
    | You've been invited to join 
    strong #{(label && label.name) || 'a label'} 
    | on Mirlo.
  p accept the invite here: 
    a(href!=`${client}/manage/${artist && artist.id ? artist.id : ''}/customize`) Accept Invite
  p 
    a(href!=`${client}/${label && (label.urlSlug || label.id) ? label.urlSlug || label.id : ''}`) View #{(label && label.name) || 'this label'} on Mirlo.
